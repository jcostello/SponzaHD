[rendering]

lights_and_shadows/use_physical_light_units=true
reflections/sky_reflections/fast_filter_high_quality=true
textures/default_filters/anisotropic_filtering_level=1
camera/depth_of_field/depth_of_field_bokeh_shape=2
camera/depth_of_field/depth_of_field_bokeh_quality=2
camera/depth_of_field/depth_of_field_use_jitter=true
scaling_3d/mode=1
environment/screen_space_reflection/roughness_quality=3
global_illumination/sdfgi/probe_ray_count=3
global_illumination/sdfgi/frames_to_update_lights=0
environment/volumetric_fog/volume_size=128
environment/volumetric_fog/use_filter=0
lightmapping/bake_performance/max_rays_per_pass=64
lightmapping/bake_performance/region_size=1024
anti_aliasing/quality/msaa_3d=1
anti_aliasing/quality/screen_space_aa=1
anti_aliasing/quality/use_taa=true
anti_aliasing/quality/use_debanding=true
environment/glow/use_high_quality=true
environment/default_environment="res://default_env.tres"
